<!-- 家庭管理 -->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 无家庭状态 -->
  <view class="no-family" wx:elif="{{!familyInfo}}">
    <view class="no-family-icon">👨‍👩‍👧‍👦</view>
    <text class="no-family-text">你还没有加入家庭</text>
    <text class="no-family-hint">创建一个家庭，邀请家人一起记账和规划日程</text>

    <button class="action-btn primary" bindtap="onOpenCreate">创建家庭</button>
    <button class="action-btn outline" bindtap="onOpenJoin">通过邀请码加入</button>
  </view>

  <!-- 有家庭状态 -->
  <view class="family-info" wx:else>
    <!-- 家庭头部 -->
    <view class="family-header">
      <view class="family-name">{{familyInfo.name}}</view>
      <view class="invite-row" bindtap="onCopyInviteCode">
        <text class="invite-label">邀请码</text>
        <text class="invite-code">{{inviteCode}}</text>
        <text class="copy-hint">点击复制</text>
      </view>
    </view>

    <!-- 成员列表 -->
    <view class="member-section">
      <view class="section-title">
        <text>家庭成员</text>
        <text class="member-count">共 {{members.length}} 人</text>
      </view>
      <view class="member-list">
        <view
          class="member-item"
          wx:for="{{members}}"
          wx:key="user_id"
        >
          <image
            class="member-avatar"
            src="{{item.avatar_url || '/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="member-info">
            <text class="member-name">{{item.nickname}}</text>
            <text class="member-role">
              {{item.role === 'creator' ? '创建者' : '成员'}}
            </text>
          </view>
          <view class="member-badge" wx:if="{{item.role === 'creator'}}">
            <text class="badge-text">主</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出按钮 -->
    <view class="leave-area">
      <button class="leave-btn" bindtap="onLeaveFamily">
        {{isCreator ? '解散家庭' : '退出家庭'}}
      </button>
    </view>
  </view>

  <!-- ====== 创建家庭弹窗 ====== -->
  <view class="dialog-mask" wx:if="{{showCreateDialog}}" bindtap="onCloseCreate">
    <view class="dialog-box" catchtap="noop">
      <view class="dialog-title">创建家庭</view>
      <input
        class="dialog-input"
        placeholder="给家庭取个名字，如「小窝」"
        value="{{createName}}"
        bindinput="onNameInput"
        maxlength="20"
        focus="{{showCreateDialog}}"
      />
      <view class="dialog-btns">
        <button class="dialog-btn cancel" bindtap="onCloseCreate">取消</button>
        <button class="dialog-btn confirm" bindtap="onConfirmCreate">创建</button>
      </view>
    </view>
  </view>

  <!-- ====== 加入家庭弹窗 ====== -->
  <view class="dialog-mask" wx:if="{{showJoinDialog}}" bindtap="onCloseJoin">
    <view class="dialog-box" catchtap="noop">
      <view class="dialog-title">加入家庭</view>
      <input
        class="dialog-input code-input"
        placeholder="输入6位邀请码"
        value="{{joinCode}}"
        bindinput="onCodeInput"
        maxlength="6"
        focus="{{showJoinDialog}}"
      />
      <view class="dialog-btns">
        <button class="dialog-btn cancel" bindtap="onCloseJoin">取消</button>
        <button class="dialog-btn confirm" bindtap="onConfirmJoin">加入</button>
      </view>
    </view>
  </view>
</view>
