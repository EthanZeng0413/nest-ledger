<!-- 统计看板 -->
<view class="container">
  <!-- 月度汇总 -->
  <view class="overview-card">
    <view class="overview-row">
      <view class="overview-item">
        <text class="label">收入</text>
        <text class="value text-income">¥{{totalIncome}}</text>
      </view>
      <view class="overview-item">
        <text class="label">支出</text>
        <text class="value text-expense">¥{{totalExpense}}</text>
      </view>
      <view class="overview-item">
        <text class="label">结余</text>
        <text class="value">¥{{balance}}</text>
      </view>
    </view>
  </view>

  <!-- 分类占比 -->
  <view class="category-section">
    <view class="section-title">支出分类</view>
    <block wx:for="{{categoryStats}}" wx:key="category">
      <view class="category-item">
        <text>{{item.category}}</text>
        <text>¥{{item.amount}} ({{item.percent}}%)</text>
      </view>
    </block>
    <view class="empty-state" wx:if="{{categoryStats.length === 0}}">
      <text>暂无数据</text>
    </view>
  </view>
</view>
