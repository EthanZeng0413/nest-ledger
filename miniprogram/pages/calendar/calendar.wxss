.container {
  min-height: 100vh;
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
}

/* 月份切换 */
.month-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx;
  background: var(--card-bg);
}

.month-arrow {
  font-size: 48rpx;
  color: var(--primary-color);
  width: 80rpx;
  text-align: center;
  line-height: 1;
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
}

/* 日历网格 */
.calendar-grid {
  background: var(--card-bg);
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.weekday-row {
  display: flex;
  border-bottom: 1rpx solid var(--border-color);
}

.weekday {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-hint);
}

.day-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell:active {
  background: var(--bg-color);
}

.day-cell.dimmed {
  opacity: 0.3;
}

.day-cell.today {
  background: var(--primary-light);
  border-radius: 8rpx;
}

.day-cell.selected {
  background: var(--primary-color);
  border-radius: 8rpx;
}

.day-cell.selected .day-num {
  color: #fff;
  font-weight: 700;
}

.day-cell.selected .event-dot {
  background: #fff;
}

.day-num {
  font-size: 30rpx;
}

.event-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary-color);
  margin-top: 6rpx;
}

/* 事件面板 */
.event-panel {
  flex: 1;
  background: var(--card-bg);
  margin: 0 20rpx;
  border-radius: 16rpx 16rpx 0 0;
  padding: 24rpx;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.panel-date {
  font-size: 28rpx;
  font-weight: 600;
}

.add-event-btn {
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 60rpx;
}

.add-event-btn text {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.event-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.event-item:last-child {
  border-bottom: none;
}

.event-left {
  flex: 1;
}

.event-title {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.event-time {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
}

.event-note {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
}

.event-right {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.event-action {
  font-size: 24rpx;
  color: var(--primary-color);
}

.event-action.delete {
  color: var(--danger-color);
}

.event-creator {
  flex-shrink: 0;
}

.event-creator text {
  font-size: 22rpx;
  color: var(--text-hint);
}

.no-events {
  text-align: center;
  padding: 60rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* 弹窗 */
.dialog-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.event-dialog {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 16rpx;
}

.field-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.field-value {
  font-size: 28rpx;
  color: var(--primary-color);
}

.dialog-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn.cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.dialog-btn.confirm {
  background: var(--primary-color);
  color: #fff;
}
