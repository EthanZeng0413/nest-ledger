.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 月份切换 */
.month-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx;
  background: var(--card-bg);
  margin-bottom: 16rpx;
}

.month-arrow {
  font-size: 48rpx;
  color: var(--primary-color);
  width: 80rpx;
  text-align: center;
  line-height: 1;
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
}

/* 总览卡片 */
.overview-card {
  background: var(--card-bg);
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.overview-row {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  text-align: center;
}

.o-label {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}

.o-value {
  font-size: 34rpx;
  font-weight: 700;
}

/* 分类区域 */
.category-section {
  background: var(--card-bg);
  margin: 0 20rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.cat-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.cat-name {
  width: 80rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cat-bar-wrapper {
  flex: 1;
  height: 16rpx;
  background: var(--bg-color);
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.cat-bar {
  height: 100%;
  background: var(--expense-color);
  border-radius: 8rpx;
  transition: width 0.5s;
}

.cat-bar.income {
  background: var(--income-color);
}

.cat-amount {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 500;
}

.cat-percent {
  width: 70rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
}
