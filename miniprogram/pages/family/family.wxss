.container {
  min-height: 100vh;
  background: var(--bg-color);
}

/* 无家庭状态 */
.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx 0;
}

.no-family-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.no-family-text {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.no-family-hint {
  font-size: 26rpx;
  color: var(--text-hint);
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.action-btn {
  width: 100%;
  height: 90rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: var(--primary-color);
  color: #fff;
}

.action-btn.outline {
  background: #fff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 家庭头部 */
.family-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 40rpx 30rpx;
  text-align: center;
}

.family-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 20rpx;
}

.invite-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 60rpx;
  padding: 12rpx 32rpx;
  width: fit-content;
  margin: 0 auto;
}

.invite-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.invite-code {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
}

.copy-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 8rpx;
}

/* 成员列表 */
.member-section {
  background: var(--card-bg);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.member-count {
  font-size: 24rpx;
  color: var(--text-hint);
  font-weight: 400;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #E0E0E0;
  margin-right: 20rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  display: block;
  margin-bottom: 4rpx;
}

.member-role {
  font-size: 24rpx;
  color: var(--text-hint);
}

.member-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-color);
  display: flex;
  justify-content: center;
  align-items: center;
}

.badge-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* 退出 */
.leave-area {
  padding: 40rpx 20rpx;
}

.leave-btn {
  width: 100%;
  height: 90rpx;
  background: #fff;
  color: var(--danger-color);
  border: 2rpx solid var(--danger-color);
  border-radius: 16rpx;
  font-size: 30rpx;
}

.leave-btn::after {
  border: none;
}

/* 弹窗 */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.dialog-box {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 30rpx;
}

.dialog-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.code-input {
  text-align: center;
  letter-spacing: 16rpx;
  font-size: 36rpx;
}

.dialog-btns {
  display: flex;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.dialog-btn::after {
  border: none;
}

.dialog-btn.cancel {
  background: var(--bg-color);
  color: var(--text-secondary);
}

.dialog-btn.confirm {
  background: var(--primary-color);
  color: #fff;
}
