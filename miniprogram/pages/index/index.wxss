.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-color);
}

/* 月份切换 */
.month-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx;
  background: var(--card-bg);
}

.month-arrow {
  font-size: 48rpx;
  color: var(--primary-color);
  width: 80rpx;
  text-align: center;
  line-height: 1;
}

.month-label {
  font-size: 32rpx;
  font-weight: 600;
}

/* 汇总栏 */
.summary-bar {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  margin: 0 20rpx 16rpx;
  padding: 24rpx 0;
  border-radius: 16rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border-color);
}

.s-label {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 8rpx;
}

.s-value {
  font-size: 36rpx;
  font-weight: 700;
}

/* 账单列表 */
.tx-list {
  flex: 1;
  padding: 0 20rpx 120rpx;
}

/* 日期组 */
.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 8rpx;
}

.date-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.date-summary {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 账单条目 */
.tx-item {
  display: flex;
  align-items: center;
  background: var(--card-bg);
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 4rpx;
}

.tx-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tx-icon.expense {
  background: #FFF3E0;
}

.tx-icon.income {
  background: #E8F5E9;
}

.tx-info {
  flex: 1;
}

.tx-category {
  font-size: 28rpx;
  display: block;
}

.tx-note {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
}

.tx-right {
  text-align: right;
}

.tx-amount {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}

.tx-amount.income {
  color: var(--income-color);
}

.tx-amount.expense {
  color: var(--expense-color);
}

.tx-user {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* FAB */
.fab {
  position: fixed;
  bottom: 140rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-color);
  box-shadow: 0 4rpx 24rpx rgba(76, 175, 80, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.fab-text {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ====== 添加弹窗 ====== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.add-dialog {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 30rpx;
  max-height: 85vh;
  overflow-y: auto;
}

/* 类型tab */
.type-tabs {
  display: flex;
  margin-bottom: 30rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-hint);
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.type-tab.active {
  font-weight: 700;
}

.type-tab.expense.active {
  color: var(--expense-color);
  border-bottom-color: var(--expense-color);
}

.type-tab.income.active {
  color: var(--income-color);
  border-bottom-color: var(--income-color);
}

/* 金额 */
.amount-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 10rpx 0;
}

.currency {
  font-size: 52rpx;
  color: var(--text-primary);
  margin-right: 8rpx;
}

.amount-input {
  font-size: 64rpx;
  font-weight: 700;
  width: 360rpx;
  text-align: left;
  border-bottom: 4rpx solid var(--border-color);
  padding-bottom: 8rpx;
}

/* 分类 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.cat-item {
  padding: 14rpx 28rpx;
  border-radius: 60rpx;
  background: var(--bg-color);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.cat-item.selected {
  background: var(--primary-light);
  color: var(--primary-color);
  font-weight: 600;
}

/* 额外字段 */
.extra-fields {
  border-top: 1rpx solid var(--border-color);
  padding-top: 20rpx;
  margin-bottom: 30rpx;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.field-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.field-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.field-input {
  text-align: right;
  font-size: 28rpx;
  width: 300rpx;
  color: var(--text-primary);
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 90rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.submit-btn::after {
  border: none;
}
