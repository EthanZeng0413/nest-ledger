<!-- 统计看板 -->
<view class="container">
  <!-- 月份切换 -->
  <view class="month-bar">
    <view class="month-arrow" bindtap="onPrevMonth">‹</view>
    <text class="month-label">{{currentMonthLabel}}</text>
    <view class="month-arrow" bindtap="onNextMonth">›</view>
  </view>

  <!-- 总览卡片 -->
  <view class="overview-card" wx:if="{{!loading}}">
    <view class="overview-row">
      <view class="overview-item">
        <text class="o-label">收入</text>
        <text class="o-value text-income">+{{totalIncome.toFixed(2)}}</text>
      </view>
      <view class="overview-item">
        <text class="o-label">支出</text>
        <text class="o-value text-expense">-{{totalExpense.toFixed(2)}}</text>
      </view>
      <view class="overview-item">
        <text class="o-label">结余</text>
        <text class="o-value {{balance >= 0 ? 'text-income' : 'text-expense'}}">
          {{balance >= 0 ? '+' : ''}}{{balance.toFixed(2)}}
        </text>
      </view>
    </view>
  </view>

  <!-- 支出分类 -->
  <view class="category-section" wx:if="{{expenseByCategory.length > 0}}">
    <view class="section-title">支出分类</view>
    <view class="cat-list">
      <view class="cat-row" wx:for="{{expenseByCategory}}" wx:key="category">
        <text class="cat-name">{{item.category}}</text>
        <view class="cat-bar-wrapper">
          <view class="cat-bar" style="width: {{item.percent}}%"></view>
        </view>
        <text class="cat-amount">¥{{item.amount.toFixed(2)}}</text>
        <text class="cat-percent">{{item.percent}}%</text>
      </view>
    </view>
  </view>

  <!-- 收入分类 -->
  <view class="category-section" wx:if="{{incomeByCategory.length > 0}}">
    <view class="section-title">收入分类</view>
    <view class="cat-list">
      <view class="cat-row" wx:for="{{incomeByCategory}}" wx:key="category">
        <text class="cat-name">{{item.category}}</text>
        <view class="cat-bar-wrapper">
          <view class="cat-bar income" style="width: {{item.percent}}%"></view>
        </view>
        <text class="cat-amount text-income">¥{{item.amount.toFixed(2)}}</text>
        <text class="cat-percent">{{item.percent}}%</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && totalIncome === 0 && totalExpense === 0}}">
    <text class="empty-icon">📊</text>
    <text class="empty-text">本月暂无数据</text>
  </view>
</view>
